# 通用（开发/本地）
# 三个后端服务端口（如需修改，请同时修改前端 Base URL 或 VITE_* 变量）
NAV_PORT=8080
PLAN_PORT=8081
RBAC_PORT=8082

# SQLite 数据库文件路径（默认使用各服务目录下相对路径）
NAV_DB_PATH=path_optimization.db
PLAN_DB_PATH=campus_emergency.db
RBAC_DB_PATH=role_management.db

# RBAC 初始化管理员密码（仅首次创建 admin 用户时生效）
ADMIN_INIT_PASSWORD=

# 是否启用单用户单会话策略（true/false）
SINGLE_SESSION_PER_USER=false

# CORS 白名单（逗号分隔，默认 *）
# 例: CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
CORS_ALLOWED_ORIGINS=*

# 细粒度 CORS（可选）：未设置时回退到 CORS_ALLOWED_ORIGINS
# public: /healthz /readyz 以及 role_management 的 /api/auth/login /api/auth/register
CORS_PUBLIC_ALLOWED_ORIGINS=
# path_optimization 与 campus_emergency 的业务 API 来源
CORS_API_ALLOWED_ORIGINS=
# role_management 的鉴权后接口来源（/api/roles /api/users /api/permissions /api/auth/me /api/auth/logout）
CORS_PROTECTED_ALLOWED_ORIGINS=

# 前端（可选）
VITE_NAV_BASE=http://localhost:8080
VITE_PLAN_BASE=http://localhost:8081
VITE_RBAC_BASE=http://localhost:8082
